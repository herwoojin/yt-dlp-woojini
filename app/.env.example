# --- backend ---
GEMINI_API_KEY=your-gemini-api-key
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
# Pro 모드는 Gemini 3 Pro 사용. 정확한 ID는 https://aistudio.google.com 에서 확인
# 사용 가능한 후보: gemini-3-pro-preview / gemini-3-pro / gemini-3-pro-latest
PRO_GEMINI_MODEL=gemini-3-pro-preview

# 영상/결과물 저장 루트. 비워두면 ~/yt-dlp-downloads 사용.
DOWNLOAD_DIR=

# YouTube가 봇 탐지/지역 제한으로 거부할 때만 필요.
# 브라우저 확장 "Get cookies.txt"로 youtube.com 쿠키 export 후 경로 지정.
YT_DLP_COOKIES_FILE=

# 텔레그램 봇 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=true

# Firebase Admin (Google 로그인 검증)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-admin.json

# 로컬 개발 중 인증 끄기 (배포 시 false 권장)
ALLOW_INSECURE_AUTH=true

# Netlify 프론트 등 CORS 허용 도메인 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.netlify.app
