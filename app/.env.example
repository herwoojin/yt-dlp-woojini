# ===========================================================================
# [JINI+US] yt-dlp 블로그 봇 — 환경설정 예시
# 개인 컴퓨터에서:  cp app/.env.example app/.env  후 값을 채우세요.
# .env 는 git에 올라가지 않습니다(.gitignore). 비밀키는 .env 에만 두세요.
# ===========================================================================

# --- Gemini (블로그/요약 생성에 필수) ---
# https://aistudio.google.com/apikey 에서 발급 (AIza... 로 시작)
GEMINI_API_KEY=your-gemini-api-key
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
PRO_GEMINI_MODEL=gemini-2.5-pro

# --- 텔레그램 봇 (모바일에서 URL 보내고 blog_long.html 받기 — 주 경로) ---
# @BotFather 에서 /newbot 으로 만들고 받은 토큰
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=true

# 영상/결과물 저장 루트. 비워두면 ~/yt-dlp-downloads 사용.
DOWNLOAD_DIR=

# YouTube가 봇 탐지/지역 제한으로 거부할 때만 필요.
# 브라우저 확장 "Get cookies.txt"로 youtube.com 쿠키 export 후 경로 지정.
YT_DLP_COOKIES_FILE=

# 로컬/개인PC 사용은 true (비밀번호·파이어베이스 불필요)
ALLOW_INSECURE_AUTH=true

# Whisper 자막 폴백 (Apple Silicon 맥에서만 동작; 그 외 OS는 자동 무시).
# 유튜브 자막이 막히면(429) 영상 음성을 받아써서 자막 생성.
WHISPER_MLX_MODEL=mlx-community/whisper-large-v3-turbo

# --- 아래는 선택 (개인PC+텔레그램만 쓰면 비워두세요) ---
# Firebase Admin (Google 로그인 검증을 쓸 때만)
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-admin.json
# 웹 UI를 외부에 열 때 CORS 허용 도메인 (쉼표 구분)
# ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# fly.dev 릴레이 (회사망 우회용 — 보통 불필요)
# REMOTE_WORKER_URL=
# WORKER_TOKEN=
# REMOTE_DISPATCH=false
