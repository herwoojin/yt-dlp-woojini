# 백엔드 API 베이스 URL (cloudflared tunnel 등)
VITE_API_BASE_URL=http://localhost:8000

# Firebase Web SDK config (Firebase console > 프로젝트 설정 > 일반 > 웹앱)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Auth 우회 (백엔드도 ALLOW_INSECURE_AUTH=true 여야 함)
VITE_ALLOW_INSECURE_AUTH=true
